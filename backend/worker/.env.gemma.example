SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
EMAIL_FROM=ihelpwithai.com <info@ihelpwithai.com>
PUBLIC_STORAGE_BASE=https://YOURPROJECT.supabase.co/storage/v1/object/public/skills

# Preferred email backend.
RESEND_API_KEY=re_your_resend_key

# SMTP fallback if RESEND_API_KEY is not set.
# SMTP_FROM=ihelpwithai.com <info@ihelpwithai.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=postmaster@example.com
# SMTP_PASSWORD=your-smtp-password

# Local Gemma on the mtj host. No Anthropic/OpenAI key is needed.
SKILLBUILDER_PROVIDER=local
SKILLBUILDER_LOCAL_BASE_URL=http://127.0.0.1:8000/v1
SKILLBUILDER_LOCAL_MODEL=gemma-4-12B-it-Q4_K_M.gguf
SKILLBUILDER_MAX_VIDEO_MINUTES=45
SKILLBUILDER_TRANSCRIBE_PROVIDER=local
SKILLBUILDER_LOCAL_TRANSCRIBE_MODEL=small.en
SKILLBUILDER_LOCAL_TRANSCRIBE_DEVICE=cpu
SKILLBUILDER_LOCAL_TRANSCRIBE_COMPUTE_TYPE=int8
WORKER_POLL_SECONDS=5

# Local copy of every verified .skill file. In docker-compose.gemma.yml this
# maps to /srv/launchpadlabs/shared/models/ihelpwithai-skill-archive on the host.
SKILL_ARCHIVE_DIR=/skill-archive
SKILL_ARCHIVE_MARKER=/skill-archive/.external-hdd-marker
